{
  "layer": "top",
  "height": 27,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/scratchpad",
    "sway/window"
  ],
  "modules-center": [
    "custom/media"
  ],
  "modules-right": [
    "idle_inhibitor",
    "backlight",
    "pulseaudio",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "network",
    "clock",
    "tray"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "disable-click": true
  },
  "sway/scratchpad": {
    "format": "{icon} {count} ",
    "show-empty": false,
    "format-icons": [
      "",
      "ΎΜΤ"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
    "format": "{title}",
    "max-length": 20
  },
  "custom/media": {
    "format": "{}",
    "escape": true,
    "return-type": "json",
    "max-length": 65,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "smooth-scrolling-threshold": 10,
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },
  "tray": {
    "icon-size": 12,
    "spacing": 13
  },
  "clock": {
    "format": "ΎΕ│ {:%a %d %b  ΎΑΩ  %H:%M}",
    "format-alt": "ΎΕ│ {:%d/%m/%Y ΎΑΩ %H:%M}",
    "interval": 1
  },
  "cpu": {
    "format": "ΎΤ╝ {usage: >3}%",
  },
  "memory": {
    "format": "ΌΚο {: >3}%",
  },
  "temperature": {
    "thermal-zone": 6,
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": [
      "ΎΜΜ",
      "ΎΜΛ",
      "ΎΜΚ",
      "ΎΜΙ",
      "ΎΜΘ"
    ]
  },
  "backlight": {
    "format": "{icon}{percent: >3}%",
    "format-icons": [
      "≤░Δη ",
      "≤░Δθ ",
      "≤░Δζ ",
      "≤░Δι "
    ]
  },
  "battery": {
    "states": {
      "good": 85,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-plugged": "{capacity}% ΎΘο",
    "format-charging": "{capacity}% ΎΘο",
    "format-icons": [
      "ΎΚΕ ",
      "ΎΚΔ ",
      "ΎΚΓ ",
      "ΎΚΒ ",
      "ΎΚΑ "
    ]
  },
  "network": {
    "format": "≤░νχ Disabled",
    "format-wifi": "{icon}{essid} ({signalStrength}%)",
    "format-ethernet": "≤░ΙΑ {ifname}: {ipaddr}/{cidr}",
    "format-disconnected": "≤░νχ Disconnected",
    "tooltip-format": "{ifname} via {gwaddr} ΎηΨ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "format-icons": [
      "≤░ντ ",
      "≤░νθ ",
      "≤░νλ ",
      "≤░νξ ",
      "≤░νρ "
    ]
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}{volume: >3}%",
    "format-muted": "≤░ζθ muted",
    "format-bluetooth": "≤░Γ▒ ≤░ΜΜ {volume}%",
    "format-icons": {
      "default": [
        "≤░ζη ",
        "ΎΑπ ",
        "≤░Χ╛ ",
        "ΎΑρ "
      ]
    }
  }
}
