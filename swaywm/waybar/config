  "height": 27,
  "modules-left": [
    "sway/workspaces",
    "hyprland/workspaces",
    "sway/mode",
    "sway/scratchpad",
    "sway/window",
    "hyprland/window"
  ],
  "modules-center": [
    "custom/media"
